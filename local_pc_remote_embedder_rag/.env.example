# Precedence for config values:
# 1) ./local_pc_remote_embedder_rag/.env (highest)
# 2) ../.env from parent RAG project
# 3) exported shell env vars / defaults in code

# Remote embedder (always used)
EMBEDDING_API_URL=http://hivecore.famnit.upr.si:6666/api/embed
EMBEDDING_API_KEY=bb86e704-c89d-4304-a709-3ef3fe514560
# optional aliases (same value as EMBEDDING_API_KEY)
EMBEDDING_BEARER_TOKEN=
BEARER_TOKEN=
EMBEDDING_API_MODEL=bge-m3
EMBEDDING_API_TIMEOUT=120
EMBEDDING_BATCH_SIZE=16
EMBEDDING_API_RETRIES=2
EMBEDDING_API_BACKOFF_SEC=1.5

# Local or remote Qdrant
# For Colima local Qdrant use: http://127.0.0.1:6333
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=JezikovneTehnologije
QDRANT_COLLECTION_REVERSE=JezikovneTehnologijeReverse
# Leave empty if local Qdrant has auth disabled
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJtIiwic3ViamVjdCI6ImFwaS1rZXk6YTQ3YWZkYTAtZjY5ZS00MTAzLWE0ZTktMGE4YjczZGNkYTEwIn0.Foo0nas1XiFnnNNaXaToKwAlL7ZgJ5G8Pzs4Z55y9UE

# CSV sources for training (folders and/or explicit CSV files, comma-separated)
# `./data,..` means: local package data folder + parent project folder (includes english_idioms_optimized.csv)
IDIOM_DATA_ROOTS=./data,..

# Retrieval tuning
RETRIEVAL_MIN_SCORE=0.15
RETRIEVAL_HYBRID_VECTOR_WEIGHT=0.75
RETRIEVAL_HYBRID_LEXICAL_WEIGHT=0.25
RETRIEVAL_EXACT_MATCH_BOOST=0.12
RETRIEVAL_PREFIX_MATCH_BOOST=0.08
RETRIEVAL_CONTAINS_MATCH_BOOST=0.05
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RETRIEVAL_CANDIDATE_MIN_LIMIT=20
CHAT_TOP_K=5

# App server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
